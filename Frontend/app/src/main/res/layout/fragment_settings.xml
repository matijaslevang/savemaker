<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".settings.SettingsFragment">

    <TextView
        android:id="@+id/settings_priority_list_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_priority_list_title"
        android:textStyle="bold"
        android:textSize="40sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/settings_priority_list_tooltip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:text="@string/settings_priority_list_tooltip"
        app:layout_constraintTop_toBottomOf="@id/settings_priority_list_title"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/settings_edit_priority_list_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_priority_list_button"
        android:backgroundTint="@color/savemaker_blue"
        android:layout_marginTop="5dp"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settings_priority_list_tooltip"/>

    <TextView
        android:id="@+id/settings_preferred_priority_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_preferred_priority_title"
        android:textStyle="bold"
        android:textSize="40sp"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toBottomOf="@id/settings_edit_priority_list_button"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/settings_preferred_priority_tooltip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:text="@string/settings_preferred_priority_tooltip"
        app:layout_constraintTop_toBottomOf="@id/settings_preferred_priority_title"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/settings_edit_preferred_priority_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_preferred_priority_button"
        android:textSize="18sp"
        android:backgroundTint="@color/savemaker_blue"
        app:layout_constraintTop_toBottomOf="@id/settings_preferred_priority_tooltip"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="5dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>